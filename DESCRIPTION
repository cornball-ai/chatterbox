Package: chatterbox
Title: Text-to-Speech Using Chatterbox TTS Engine
Version: 0.1.0
Authors@R:
    c(person("Troy", "Hernandez", role = c("aut", "cre"),
             email = "troy@cornball.ai",
             comment = c(ORCID = "0009-0005-4248-604X")),
